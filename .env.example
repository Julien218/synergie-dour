# =============================================================================
# Variables d'environnement Synergie Dour
# =============================================================================
#
# Copier ce fichier en .env (sans .example) et remplir les valeurs.
# Sur Railway : aller dans Settings > Variables et tout coller depuis ce fichier.
#
# NE JAMAIS COMMITTER LE FICHIER .env (déjà dans .gitignore normalement).
#
# Plateforme conçue par JS-Innov.IA — www.jsinnovia.com
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données — fournie par Railway
# -----------------------------------------------------------------------------
DATABASE_URL="mysql://user:password@host:port/database"

# -----------------------------------------------------------------------------
# Anthropic API — pour l'agent de vérification hebdomadaire
# -----------------------------------------------------------------------------
# Obtenir sur https://console.anthropic.com — facturé à l'usage (~5€/mois)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# -----------------------------------------------------------------------------
# Stripe Connect — paiements ASBL
# -----------------------------------------------------------------------------
# Votre compte Stripe (JS-Innov.IA) est la PLATEFORME.
# L'ASBL crée son compte Connect — son ID est stocké en BDD, pas ici.
#
# Mode test pour développement : clés commencent par sk_test_ et pk_test_
# Mode live pour production : sk_live_ et pk_live_
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret — créé dans Stripe Dashboard > Developers > Webhooks
# Pour le webhook : https://www.synergiedour.be/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Application Fee — votre commission par adhésion en CENTIMES
# 250 = 2,50€ comme convenu
STRIPE_APPLICATION_FEE_CENTS="250"

# Prix de l'adhésion en centimes (50,00 €)
MEMBERSHIP_PRICE_CENTS="5000"

# IDs des prix Stripe (à créer une fois dans Stripe Dashboard)
STRIPE_PRICE_ID_ONE_TIME="price_..."          # paiement annuel one-shot
STRIPE_PRICE_ID_SUBSCRIPTION="price_..."      # abonnement annuel récurrent

# -----------------------------------------------------------------------------
# Resend — envoi d'emails depuis @synergiedour.be
# -----------------------------------------------------------------------------
# Créer un compte sur https://resend.com (gratuit jusqu'à 100 mails/jour).
# Ajouter le domaine synergiedour.be et configurer les DNS (SPF + DKIM).
RESEND_API_KEY="re_..."

# Adresses d'envoi
EMAIL_FROM_NOREPLY="Synergie Dour <noreply@synergiedour.be>"
EMAIL_FROM_CONTACT="Synergie Dour <contact@synergiedour.be>"

# Destinataires des notifications agent (présidence + secrétariat ASBL)
EMAIL_ADMIN_NOTIF="olivier.trevis@synergiedour.be,daisy.audin@synergiedour.be"

# -----------------------------------------------------------------------------
# Configuration de l'application
# -----------------------------------------------------------------------------
NODE_ENV="production"
APP_URL="https://www.synergiedour.be"
APP_SUPPORT_EMAIL="contact@synergiedour.be"

# Secret pour signer les sessions (générer avec : openssl rand -hex 32)
SESSION_SECRET="..."

# Token secret pour autoriser le cron (généré aléatoirement)
# Le cron Railway envoie ce token dans l'header pour s'authentifier
CRON_SECRET="..."

# -----------------------------------------------------------------------------
# Manus OAuth — déjà existant dans votre projet
# -----------------------------------------------------------------------------
MANUS_OAUTH_CLIENT_ID="..."
MANUS_OAUTH_CLIENT_SECRET="..."
